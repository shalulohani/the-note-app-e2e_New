import { test, expect } from '@playwright/test';

test.describe('Login Negative Tests', () => {
  test.beforeEach(async ({ page }) => {
    await page.goto('http://localhost:3000/login');
  });

  test('Invalid username and valid password', async ({ page }) => {
    await page.fill('input[placeholder="Username"]', 'wrongUser');
    await page.fill('input[placeholder="Password"]', 'admin123');
    await page.click('button:has-text("Login")');

    await expect(page.locator('.error-message')).toHaveText('Invalid credentials');
  });

  test('Valid username and invalid password', async ({ page }) => {
    await page.fill('input[placeholder="Username"]', 'admin');
    await page.fill('input[placeholder="Password"]', 'wrongPass');
    await page.click('button:has-text("Login")');

    await expect(page.locator('.error-message')).toHaveText('Invalid credentials');
  });

  test('Empty username and valid password', async ({ page }) => {
    await page.fill('input[placeholder="Password"]', 'admin123');
    await page.click('button:has-text("Login")');

    await expect(page.locator('.error-message')).toHaveText('Username is required');
  });

  test('Valid username and empty password', async ({ page }) => {
    await page.fill('input[placeholder="Username"]', 'admin');
    await page.click('button:has-text("Login")');

    await expect(page.locator('.error-message')).toHaveText('Password is required');
  });

  test('Empty username and empty password', async ({ page }) => {
    await page.click('button:has-text("Login")');

    await expect(page.locator('.error-message')).toHaveText('Username and password required');
  });
});
